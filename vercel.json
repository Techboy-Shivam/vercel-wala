{
  "version": 2,
  "builds": [
    { "src": "Backend/", "use": "@vercel/" },
    { "src": "Frontend/n", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "source": "/apii/(*)",
      "destination": "Backend/"
    },
    {
      "source": "/(.*)",
      "destination": "Frontend/"
    }
  ]
}
